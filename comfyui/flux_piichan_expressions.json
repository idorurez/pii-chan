eed","name":"noise_seed","type":"INT","widget":{"name":"noise_seed"},"link":null}],"outputs":[{"localized_name":"NOISE","name":"NOISE","type":"NOISE","links":[37]}],"properties":{"cnr_id":"comfy-core","ver":"0.8.2","Node name for S&R":"RandomNoise"},"widgets_values":[1122296948538618,"fixed"],"color":"#2a363b","bgcolor":"#3f5159"},{"id":28,"type":"Note","pos":[109.71004284667941,516.7100113220215],"size":[336,288],"flags":{},"order":11,"mode":0,"inputs":[],"outputs":[],"properties":{"text":""},"widgets_values":["If you get an error in any of the nodes above make sure the files are in the correct directories.\n\nSee the top of the examples page for the links : https://comfyanonymous.github.io/ComfyUI_examples/flux/\n\nflux1-dev.safetensors goes in: ComfyUI/models/unet/\n\nt5xxl_fp16.safetensors and clip_l.safetensors go in: ComfyUI/models/clip/\n\nae.safetensors goes in: ComfyUI/models/vae/\n\n\nTip: You can set the weight_dtype above to one of the fp8 types if you have memory issues."],"color":"#432","bgcolor":"#653"},{"id":43,"type":"Note","pos":[-836.926801451943,381.03430220291807],"size":[800,300],"flags":{},"order":12,"mode":0,"inputs":[],"outputs":[],"title":"Instructions","properties":{},"widgets_values":["=== PIi-CHAN EXPRESSION WORKFLOW ===\n\nHOW TO USE:\n\n2. CREATE REFERENCE:\n   - Generate or load your ideal pii-chan neutral image\n   - Save it as 'pii-chan_reference.png'\n   - This locks the character design\n\n3. GENERATE EXPRESSIONS:\n   Change the [EXPRESSION: ...] part in the positive prompt:\n\n   neutral:   [EXPRESSION: calm expression, slight smile, looking at viewer]\n   happy:     [EXPRESSION: happy, big smile, closed eyes, blush, sparkles]\n   sad:       [EXPRESSION: sad expression, frown, downcast eyes, tears]\n   surprised: [EXPRESSION: surprised, wide eyes, open mouth, shocked, !]\n   thinking:  [EXPRESSION: thinking, looking up, finger on chin, pondering]\n   sleepy:    [EXPRESSION: sleepy, half-closed eyes, drowsy, tired, zzz]\n   talking:   [EXPRESSION: talking, open mouth, speaking, mid-sentence]\n   excited:   [EXPRESSION: very happy, excited, sparkle eyes, grin, jumping]\n   confused:  [EXPRESSION: confused, head tilt, raised eyebrow, question mark]\n\n4. TIPS:\n   - Keep same seed for consistency (or try different seeds)\n   - IP-Adapter weight 0.8-0.9 works well\n   - If face drifts, increase IP-Adapter weight\n   - Use same prompt prefix, only change [EXPRESSION: ...]\n"],"color":"#432","bgcolor":"#653"}],"links":[[9,8,0,9,0,"IMAGE"],[12,10,0,8,1,"VAE"],[19,16,0,13,2,"SAMPLER"],[20,17,0,13,3,"SIGMAS"],[24,13,0,8,0,"LATENT"],[30,22,0,13,1,"GUIDER"],[37,25,0,13,0,"NOISE"],[41,6,0,26,0,"CONDITIONING"],[42,26,0,22,1,"CONDITIONING"],[54,30,0,22,0,"MODEL"],[55,30,0,17,0,"MODEL"],[112,34,0,27,0,"INT"],[113,35,0,27,1,"INT"],[114,35,0,30,4,"INT"],[115,34,0,30,3,"INT"],[116,27,0,13,4,"LATENT"],[117,11,0,38,1,"CLIP"],[118,38,0,30,0,"MODEL"],[119,38,1,6,0,"CLIP"],[120,12,0,38,0,"MODEL"]],"groups":[],"config":{},"extra":{"ds":{"scale":0.7513148009015783,"offset":[1694.816782988808,160.32720883109312]},"workflowRendererVersion":"LG","groupNodes":{},"node_versions":{"comfy-core":"0.3.52"}},"version":0.4}