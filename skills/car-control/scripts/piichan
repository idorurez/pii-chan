#!/usr/bin/env python3
"""
Pii-chan CLI - Vehicle control via CAN bus

Commands:
  state         Read current vehicle state
  climate       Set climate control
  climate-off   Turn off climate
  sniff         Capture CAN traffic for reverse engineering
  can-write     Send raw CAN message (dangerous!)
"""

import argparse
import json
import sys
import time
from pathlib import Path

# Try to import CAN library (may not be available in dev)
try:
    import can
    CAN_AVAILABLE = True
except ImportError:
    CAN_AVAILABLE = False


def mock_state():
    """Return mock vehicle state for testing."""
    return {
        "engine_running": True,
        "speed_kmh": 0,
        "gear": "P",
        "battery_soc": 78,
        "fuel_level": 65,
        "climate": {
            "driver_temp": 72,
            "passenger_temp": 72,
            "rear_temp": 70,
            "fan": 3,
            "mode": "auto",
            "sync": True
        },
        "doors": {
            "fl": False, "fr": False,
            "rl": False, "rr": False,
            "trunk": False
        }
    }


def cmd_state(args):
    """Read current vehicle state."""
    if not CAN_AVAILABLE or args.mock:
        print(json.dumps(mock_state(), indent=2))
        return
    
    # TODO: Actual CAN reading
    # bus = can.Bus(channel='can0', bustype='socketcan')
    # ... read state messages ...
    print(json.dumps(mock_state(), indent=2))


def cmd_climate(args):
    """Set climate control."""
    settings = {}
    
    if args.zone:
        settings['zone'] = args.zone
    if args.temp:
        settings['temp'] = args.temp
    if args.fan is not None:
        settings['fan'] = args.fan
    if args.mode:
        settings['mode'] = args.mode
    if args.sync:
        settings['sync'] = args.sync.lower() == 'on'
    
    if not settings:
        print("Error: No climate settings provided", file=sys.stderr)
        print("Use: piichan climate --zone rear --temp 72 --mode feet", file=sys.stderr)
        sys.exit(1)
    
    print(f"Setting climate: {json.dumps(settings)}")
    
    if not CAN_AVAILABLE or args.mock:
        print("(Mock mode - no actual CAN write)")
        print(json.dumps({"success": True, "settings": settings}, indent=2))
        return
    
    # TODO: Actual CAN writing
    # Write appropriate CAN messages based on settings
    print(json.dumps({"success": True, "settings": settings}, indent=2))


def cmd_climate_off(args):
    """Turn off climate control."""
    print("Turning off climate control...")
    
    if not CAN_AVAILABLE or args.mock:
        print("(Mock mode - no actual CAN write)")
        print(json.dumps({"success": True, "message": "Climate off"}, indent=2))
        return
    
    # TODO: Send climate off CAN message
    print(json.dumps({"success": True, "message": "Climate off"}, indent=2))


def cmd_sniff(args):
    """Capture CAN traffic for reverse engineering."""
    duration = args.duration or 30
    filter_id = int(args.filter, 16) if args.filter else None
    
    print(f"Sniffing CAN for {duration}s...", file=sys.stderr)
    
    if not CAN_AVAILABLE or args.mock:
        # Return mock sniff data
        mock_data = {
            "0x123": {"count": 150, "unique_values": 3, "samples": ["0102030405060708", "0102030405060709"]},
            "0x456": {"count": 50, "unique_values": 12, "samples": ["FF00FF00FF00FF00", "FE01FE01FE01FE01"]},
            "0x789": {"count": 300, "unique_values": 1, "samples": ["0000000000000000"]},
        }
        print(json.dumps(mock_data, indent=2))
        return
    
    # Actual CAN sniffing
    from collections import defaultdict
    
    bus = can.Bus(channel='can0', bustype='socketcan')
    messages = defaultdict(list)
    
    start = time.time()
    while time.time() - start < duration:
        msg = bus.recv(timeout=0.1)
        if msg:
            if filter_id is None or msg.arbitration_id == filter_id:
                messages[hex(msg.arbitration_id)].append({
                    'time': round(time.time() - start, 3),
                    'data': msg.data.hex()
                })
    
    # Build summary
    summary = {}
    for arb_id, msgs in messages.items():
        unique_data = set(m['data'] for m in msgs)
        summary[arb_id] = {
            'count': len(msgs),
            'unique_values': len(unique_data),
            'samples': list(unique_data)[:5]
        }
    
    print(json.dumps(summary, indent=2))
    
    # Optionally save raw data
    if args.output:
        with open(args.output, 'w') as f:
            json.dump(dict(messages), f, indent=2)
        print(f"Raw capture saved to {args.output}", file=sys.stderr)


def cmd_can_write(args):
    """Send raw CAN message (dangerous!)."""
    arb_id = int(args.id, 16)
    data = bytes.fromhex(args.data)
    
    print(f"Writing CAN: ID={hex(arb_id)}, Data={data.hex()}", file=sys.stderr)
    
    if not CAN_AVAILABLE or args.mock:
        print("(Mock mode - no actual CAN write)")
        print(json.dumps({"success": True, "id": hex(arb_id), "data": data.hex()}, indent=2))
        return
    
    bus = can.Bus(channel='can0', bustype='socketcan')
    msg = can.Message(arbitration_id=arb_id, data=data, is_extended_id=False)
    bus.send(msg)
    print(json.dumps({"success": True, "id": hex(arb_id), "data": data.hex()}, indent=2))


def main():
    parser = argparse.ArgumentParser(description='Pii-chan Vehicle Control')
    parser.add_argument('--mock', action='store_true', help='Use mock data (no CAN)')
    
    subparsers = parser.add_subparsers(dest='command', required=True)
    
    # state
    sub_state = subparsers.add_parser('state', help='Read vehicle state')
    sub_state.set_defaults(func=cmd_state)
    
    # climate
    sub_climate = subparsers.add_parser('climate', help='Set climate control')
    sub_climate.add_argument('--zone', choices=['driver', 'passenger', 'rear', 'all'])
    sub_climate.add_argument('--temp', type=int, help='Temperature 60-85°F')
    sub_climate.add_argument('--fan', type=int, help='Fan speed 0-7 (0=auto)')
    sub_climate.add_argument('--mode', choices=['auto', 'face', 'feet', 'both', 'defrost'])
    sub_climate.add_argument('--sync', choices=['on', 'off'])
    sub_climate.set_defaults(func=cmd_climate)
    
    # climate-off
    sub_off = subparsers.add_parser('climate-off', help='Turn off climate')
    sub_off.set_defaults(func=cmd_climate_off)
    
    # sniff
    sub_sniff = subparsers.add_parser('sniff', help='Capture CAN traffic')
    sub_sniff.add_argument('--duration', type=int, default=30, help='Capture duration (seconds)')
    sub_sniff.add_argument('--filter', help='Filter by arbitration ID (hex)')
    sub_sniff.add_argument('--output', help='Save raw capture to file')
    sub_sniff.set_defaults(func=cmd_sniff)
    
    # can-write (dangerous)
    sub_write = subparsers.add_parser('can-write', help='Send raw CAN message')
    sub_write.add_argument('id', help='Arbitration ID (hex)')
    sub_write.add_argument('data', help='Data bytes (hex)')
    sub_write.set_defaults(func=cmd_can_write)
    
    args = parser.parse_args()
    args.func(args)


if __name__ == '__main__':
    main()
